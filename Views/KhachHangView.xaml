<UserControl x:Class="Quanlybanhang.Views.KhachHangView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Background="#F5F7FA" Margin="15">

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="280"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- FORM -->
        <Border Grid.Column="0"
                Background="White"
                CornerRadius="10"
                Padding="15"
                Margin="0,0,10,0">

            <StackPanel>

                <TextBlock Text="Thông tin khách hàng"
                           FontSize="18"
                           FontWeight="Bold"
                           Margin="0,0,0,15"/>

                <!-- Mã KH -->
                <TextBlock Text="Mã khách hàng"/>
                <TextBox Text="{Binding KhachHangDangChon.MaKH}"
                         Margin="0,5,0,10"
                         Height="30"/>

                <!-- Tên KH -->
                <TextBlock Text="Tên khách hàng"/>
                <TextBox Text="{Binding KhachHangDangChon.TenKH}"
                         Margin="0,5,0,10"
                         Height="30"/>

                <!-- SĐT -->
                <TextBlock Text="Số điện thoại"/>
                <TextBox Text="{Binding KhachHangDangChon.SoDienThoai}"
                         Margin="0,5,0,15"
                         Height="30"/>

                <!-- BUTTON -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">

                    <Button Content="Thêm"
                            Width="70"
                            Margin="5"
                            Background="#4CAF50"
                            Foreground="White"
                            BorderThickness="0"
                            Click="Them_Click"/>

                    <Button Content="Sửa"
                            Width="70"
                            Margin="5"
                            Background="#2196F3"
                            Foreground="White"
                            BorderThickness="0"
                            Click="Sua_Click"/>

                    <Button Content="Xóa"
                            Width="70"
                            Margin="5"
                            Background="#F44336"
                            Foreground="White"
                            BorderThickness="0"
                            Click="Xoa_Click"/>

                </StackPanel>

            </StackPanel>
        </Border>

        <!-- DANH SÁCH -->
        <Border Grid.Column="1"
                Background="White"
                CornerRadius="10"
                Padding="15">

            <StackPanel>

                <TextBlock Text="Danh sách khách hàng"
                           FontSize="18"
                           FontWeight="Bold"
                           Margin="0,0,0,10"/>

                <!-- Search -->
                <TextBox Width="250"
                         Height="30"
                         Margin="0,0,0,10"
                         Padding="5"
                         Text="{Binding TuKhoa, UpdateSourceTrigger=PropertyChanged}"
                         ToolTip="Nhập để tìm kiếm..."/>

                <!-- List -->
                <ListView ItemsSource="{Binding DanhSachKhachHang}"
                          SelectedItem="{Binding KhachHangDangChon}"
                          BorderThickness="0">

                    <ListView.View>
                        <GridView>

                            <GridViewColumn Header="Mã KH"
                                            DisplayMemberBinding="{Binding MaKH}"
                                            Width="100"/>

                            <GridViewColumn Header="Tên KH"
                                            DisplayMemberBinding="{Binding TenKH}"
                                            Width="180"/>

                            <GridViewColumn Header="SĐT"
                                            DisplayMemberBinding="{Binding SoDienThoai}"
                                            Width="140"/>

                        </GridView>
                    </ListView.View>

                </ListView>

            </StackPanel>
        </Border>

    </Grid>

</UserControl>