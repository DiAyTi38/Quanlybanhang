<Window x:Class="Quanlybanhang.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:viewModels="clr-namespace:Quanlybanhang.ViewModels"
        Title="Quản Lý Đồ Secondhand (MVVM)" Height="600" Width="900"
        WindowStartupLocation="CenterScreen">
    
    <!-- Liên kết Giao diện này tới ViewModel của nó -->
    <Window.DataContext>
        <viewModels:MainViewModel />
    </Window.DataContext>

    <!-- Nền App và bố cục chia 2 cột -->
    <Grid Background="#f0f2f5">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="300" /> <!-- Cột bên trái: Thêm sản phẩm -->
            <ColumnDefinition Width="*" />   <!-- Cột bên phải: Danh sách -->
        </Grid.ColumnDefinitions>

        <!-- PANEL BÊN TRÁI: Form Thêm mới -->
        <Border Grid.Column="0" Background="White" Margin="10" Padding="15" CornerRadius="8" BorderBrush="#e0e0e0" BorderThickness="1">
            <StackPanel>
                <TextBlock Text="NHẬP HÀNG MỚI" FontSize="18" FontWeight="Bold" Foreground="#333" Margin="0,0,0,15" HorizontalAlignment="Center"/>

                <TextBlock Text="Mã sản phẩm:" FontWeight="SemiBold" Margin="0,10,0,5"/>
                <!-- UpdateSourceTrigger=PropertyChanged giúp update ViewModel ngay khi gõ phím, để nút Thêm sáng lên lập tức -->
                <TextBox Text="{Binding NewId, UpdateSourceTrigger=PropertyChanged}" Padding="5" />

                <TextBlock Text="Tên sản phẩm:" FontWeight="SemiBold" Margin="0,15,0,5"/>
                <TextBox Text="{Binding NewName, UpdateSourceTrigger=PropertyChanged}" Padding="5" />

                <TextBlock Text="Giá bán (VNĐ):" FontWeight="SemiBold" Margin="0,15,0,5"/>
                <TextBox Text="{Binding NewPrice, UpdateSourceTrigger=PropertyChanged}" Padding="5" />

                <TextBlock Text="Tình trạng:" FontWeight="SemiBold" Margin="0,15,0,8"/>
                <StackPanel Orientation="Horizontal">
                    <RadioButton Content="Mới 100%" IsChecked="{Binding NewIsNew}" Margin="0,0,15,0"/>
                    <!-- Nếu NewIsNew là false, thì nút Secondhand này tự động được chọn -->
                    <RadioButton Content="Secondhand" IsChecked="True"/> 
                </StackPanel>

                <!-- Nút bấm gọi thẳng Data Binding lên Command của ViewModel -->
                <Button Content="Thêm vào kho" 
                        Command="{Binding AddCommand}" 
                        Background="#4CAF50" Foreground="White" FontWeight="Bold" 
                        Margin="0,30,0,0" Padding="10" 
                        Cursor="Hand"/>
            </StackPanel>
        </Border>

        <!-- PANEL BÊN PHẢI: Tìm kiếm và Danh sách -->
        <Grid Grid.Column="1" Margin="0,10,10,10">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Khung tìm kiếm -->
            <Border Grid.Row="0" Background="White" Padding="10" CornerRadius="8" BorderBrush="#e0e0e0" BorderThickness="1" Margin="0,0,0,10">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="🔍 Tìm kiếm:" VerticalAlignment="Center" FontWeight="SemiBold" Margin="0,0,10,0"/>
                    <TextBox Text="{Binding SearchKeyword, UpdateSourceTrigger=PropertyChanged}" Width="300" Padding="5" 
                             ToolTip="Nhập mã hoặc tên sản phẩm..." />
                </StackPanel>
            </Border>

            <!-- Bảng dữ liệu sản phẩm -->
            <Border Grid.Row="1" Background="White" CornerRadius="8" BorderBrush="#e0e0e0" BorderThickness="1" Padding="10">
                <DataGrid ItemsSource="{Binding Products}" 
                          AutoGenerateColumns="False" 
                          CanUserAddRows="False" 
                          HeadersVisibility="Column" 
                          IsReadOnly="True" 
                          RowHeight="35"
                          GridLinesVisibility="Horizontal" >
                    <!-- Cột DataGrid -->
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Mã Hàng" Binding="{Binding Id}" Width="80"/>
                        <DataGridTextColumn Header="Tên Sản Phẩm" Binding="{Binding Name}" Width="*"/>
                        <DataGridTextColumn Header="Giá Bán" Binding="{Binding Price, StringFormat={}{0:N0} đ}" Width="100"/>
                        <DataGridTextColumn Header="Tình trạng" Binding="{Binding Condition}" Width="150"/>
                        
                        <!-- Cột chứa Nút Xóa -->
                        <DataGridTemplateColumn Header="Hành động" Width="80">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Button Content="Xóa" 
                                            Command="{Binding DataContext.DeleteCommand, RelativeSource={RelativeSource AncestorType=Window}}" 
                                            CommandParameter="{Binding}" 
                                            Background="#f44336" Foreground="White" 
                                            Margin="5,2" Cursor="Hand"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>
        </Grid>
    </Grid>
</Window>
