<UserControl x:Class="Quanlybanhang.Views.ThongKeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:Quanlybanhang.ViewModels" Height="308" Width="428">

    <UserControl.DataContext>
        <vm:ThongKeViewModel />
    </UserControl.DataContext>

    <Grid Margin="20">
        <StackPanel>
            <DockPanel>
                <TextBlock Text="          THỐNG KÊ BÁN HÀNG" FontSize="24" FontWeight="Bold" DockPanel.Dock="Left" />
            </DockPanel>

            <UniformGrid Columns="2" Rows="2" Margin="0,20,0,0" HorizontalAlignment="Stretch">
                <!-- Card: Doanh thu hôm nay -->
                <Border Background="#ffffff" BorderBrush="#e0e0e0" BorderThickness="1" CornerRadius="6" Padding="12" Margin="8">
                    <StackPanel>
                        <TextBlock Text="Doanh thu hôm nay" FontWeight="SemiBold" Foreground="#444" />
                        <TextBlock Text="{Binding DoanhThuNgay, StringFormat={}{0:N0} đ}" FontSize="20" FontWeight="Bold" Margin="0,8,0,0" Foreground="#2e7d32" />
                    </StackPanel>
                </Border>

                <!-- Card: Doanh thu tháng -->
                <Border Background="#ffffff" BorderBrush="#e0e0e0" BorderThickness="1" CornerRadius="6" Padding="12" Margin="8">
                    <StackPanel>
                        <TextBlock Text="Doanh thu tháng" FontWeight="SemiBold" Foreground="#444" />
                        <TextBlock Text="{Binding DoanhThuThang, StringFormat={}{0:N0} đ}" FontSize="20" FontWeight="Bold" Margin="0,8,0,0" Foreground="#1565c0" />
                    </StackPanel>
                </Border>

                <!-- Card: Số sản phẩm đã bán -->
                <Border Background="#ffffff" BorderBrush="#e0e0e0" BorderThickness="1" CornerRadius="6" Padding="12" Margin="8">
                    <StackPanel>
                        <TextBlock Text="Số sản phẩm đã bán" FontWeight="SemiBold" Foreground="#444" />
                        <TextBlock Text="{Binding SoSanPhamBan}" FontSize="20" FontWeight="Bold" Margin="0,8,0,0" Foreground="#ff8f00" />
                    </StackPanel>
                </Border>

                <!-- Card: Tồn kho -->
                <Border Background="#ffffff" BorderBrush="#e0e0e0" BorderThickness="1" CornerRadius="6" Padding="12" Margin="8">
                    <StackPanel>
                        <TextBlock Text="Tồn kho" FontWeight="SemiBold" Foreground="#444" />
                        <TextBlock Text="{Binding TonKho}" FontSize="20" FontWeight="Bold" Margin="0,8,0,0" Foreground="#6a1b9a" />
                    </StackPanel>
                </Border>
            </UniformGrid>
        </StackPanel>
        <Button Content="Làm mới" Padding="6" Click="Refresh_Click" Margin="97,247,97,-11" />
    </Grid>
</UserControl>