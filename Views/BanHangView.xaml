<UserControl x:Class="Quanlybanhang.Views.BanHangView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:viewModels="clr-namespace:Quanlybanhang.ViewModels"
             Background="White">

    <UserControl.DataContext>
        <viewModels:BanHangViewModel />
    </UserControl.DataContext>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Top: Chọn Khách Hàng -->
        <Border Grid.Row="0" Margin="0,0,0,10" Padding="10" BorderBrush="#ccc" BorderThickness="1" CornerRadius="5">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="Chọn Khách Hàng:" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,10,0"/>
                <ComboBox ItemsSource="{Binding Customers}" 
                          SelectedItem="{Binding SelectedCustomer}" 
                          DisplayMemberPath="TenKH" 
                          Width="300" Padding="5"/>
                <TextBlock Text="(Ràng buộc: Bắt buộc chọn khách)" Margin="10,0,0,0" FontStyle="Italic" Foreground="Gray" VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="20"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- L: Danh sách Sản phẩm -->
            <Border Grid.Column="0" BorderBrush="#ccc" BorderThickness="1" CornerRadius="5" Padding="10">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Text="🛒 Sản Phẩm Có Sẵn" FontWeight="Bold" FontSize="16" Margin="0,0,0,10"/>
                    <DataGrid Grid.Row="1" ItemsSource="{Binding AvailableProducts}" AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True" RowHeight="35">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Tên SP" Binding="{Binding Name}" Width="*"/>
                            <DataGridTextColumn Header="Giá" Binding="{Binding Price, StringFormat={}{0:N0}}" Width="90"/>
                            <DataGridTemplateColumn Header="Thêm" Width="70">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Button Content="+" Command="{Binding DataContext.AddToCartCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding}" Background="#4CAF50" Foreground="White" Cursor="Hand" Width="30" FontWeight="Bold"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>

            <!-- R: Giỏ hàng -->
            <Border Grid.Column="2" BorderBrush="#ccc" BorderThickness="1" CornerRadius="5" Padding="10">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Text="📋 Hoá Đơn Tạm Tính" FontWeight="Bold" FontSize="16" Margin="0,0,0,10"/>
                    <DataGrid Grid.Row="1" ItemsSource="{Binding Cart}" AutoGenerateColumns="False" CanUserAddRows="False" RowHeight="35">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Tên SP" Binding="{Binding SanPham.Name}" Width="*" IsReadOnly="True"/>
                            <DataGridTextColumn Header="SL" Binding="{Binding SoLuong, UpdateSourceTrigger=PropertyChanged}" Width="50"/>
                            <DataGridTextColumn Header="Thành Tiền" Binding="{Binding ThanhTien, StringFormat={}{0:N0}}" Width="90" IsReadOnly="True"/>
                            <DataGridTemplateColumn Header="Bỏ" Width="50">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Button Content="X" Command="{Binding DataContext.RemoveFromCartCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding}" Background="#f44336" Foreground="White" Cursor="Hand" Width="30" FontWeight="Bold"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>
        </Grid>

        <!-- Bottom: Thanh toán -->
        <Border Grid.Row="2" Margin="0,10,0,0" Padding="15" Background="#f8f9fa" BorderBrush="#ccc" BorderThickness="1" CornerRadius="5">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <TextBlock Text="Tổng Tiền: " FontSize="20" FontWeight="Bold" VerticalAlignment="Center"/>
                <TextBlock Text="{Binding TongTien, StringFormat={}{0:N0} đ}" FontSize="24" FontWeight="Bold" Foreground="#d32f2f" VerticalAlignment="Center" Margin="0,0,20,0"/>
                <Button Content="XUẤT HOÁ ĐƠN" Command="{Binding CheckoutCommand}" Background="#2196F3" Foreground="White" FontWeight="Bold" FontSize="16" Padding="20,10" Cursor="Hand"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
